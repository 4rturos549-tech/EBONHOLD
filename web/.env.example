# =========================================================
# Ebonhold - Variables de entorno de la web
# Copia este archivo a .env.local y rellena los valores.
# =========================================================

# BD propia de la web (ebonhold_web)
# Vive en la misma instancia MySQL que las BDs del server.
DATABASE_URL="mysql://root:azerothcore@localhost:3306/ebonhold_web"

# Conexion read/write a las BDs de AzerothCore (acore_auth, acore_characters).
# Usado para:
#  - listar jugadores online por reino
#  - crear cuentas desde el formulario de registro
# Si la dejas vacia, la web funcionara igualmente con reinos offline
# y el registro deshabilitado.
ACORE_DATABASE_URL="mysql://root:azerothcore@localhost:3306/"

# URL canonica del sitio (para SEO, sitemaps, etc)
NEXT_PUBLIC_SITE_URL="https://ebonhold.example.com"
